# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# Local (supabase start) -> use os valores impressos no terminal.
# Produção -> Project Settings > API no dashboard do Supabase.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Apenas para uso server-side privilegiado (NUNCA expor no client).
# Opcional nesta fase.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
